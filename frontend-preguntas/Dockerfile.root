# syntax=docker/dockerfile:1.7
FROM node:20-alpine AS build

WORKDIR /frontend

COPY frontend-preguntas/package*.json ./
RUN --mount=type=cache,target=/root/.npm sh -c 'if [ -f package-lock.json ]; then npm ci; else npm install; fi'
COPY frontend-preguntas/ .
RUN npm run build

FROM nginx:1.27-alpine

COPY frontend-preguntas/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /frontend/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
