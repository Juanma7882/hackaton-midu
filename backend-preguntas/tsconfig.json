{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",

    "moduleResolution": "bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}